{
  "schema": "https://serenorg.github.io/dispatch/schemas/extension.v1.json",
  "kind": "channel",
  "name": "channel-whatsapp",
  "version": "0.1.0",
  "protocol": "jsonl",
  "protocol_version": 1,
  "description": "WhatsApp Cloud API channel plugin for Dispatch.",
  "entrypoint": {
    "command": "../../target/release/channel-whatsapp",
    "args": []
  },
  "auth": {
    "mode": "manual",
    "provider": "Meta",
    "setup_url": "https://developers.facebook.com/apps/"
  },
  "capabilities": {
    "channel": {
      "platform": "whatsapp",
      "ingress_modes": ["webhook"],
      "outbound_message_types": ["text"],
      "threading_model": "phone_number",
      "attachment_support": true,
      "reply_verification_support": true,
      "account_scoped_config": true,
      "allow_polling": false,
      "webhook_secret_support": true,
      "allowed_paths": ["/whatsapp/webhook"],
      "delivery": {
        "push": true,
        "status_frames": true,
        "attachment_sources": ["data_base64", "url", "storage_key"]
      }
    }
  },
  "requirements": {
    "secrets": ["WHATSAPP_ACCESS_TOKEN"],
    "optional_secrets": ["WHATSAPP_VERIFY_TOKEN", "WHATSAPP_APP_SECRET"],
    "network_domains": ["graph.facebook.com"]
  }
}
